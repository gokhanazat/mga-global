# Cloudflare Pages Headers configuration
# Relaxing headers for better compatibility on custom domains

/*
  Access-Control-Allow-Origin: *
  Cross-Origin-Embedder-Policy: unsafe-none
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: cross-origin
  X-Content-Type-Options: nosniff
  # Allowed self and cloudflare insights to prevent path interference errors
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://static.cloudflareinsights.com;

# Explicit MIME types for WASM
/*.wasm
  Content-Type: application/wasm
  Access-Control-Allow-Origin: *
  Cache-Control: no-cache, no-store, must-revalidate

# Explicit MIME types for JS
/*.js
  Content-Type: application/javascript
  Access-Control-Allow-Origin: *


